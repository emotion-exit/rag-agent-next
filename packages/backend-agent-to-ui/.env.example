LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true|false
LANGSMITH_PROJECT=your_langsmith_project_name_here

OPENROUTER_MODEL=your_openrouter_model_here
OPENROUTER_MODEL_PRO=your_openrouter_model_pro_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

GOOGLE_MODEL=your_google_model_here
GOOGLE_MODEL_PRO=your_google_model_pro_here
GOOGLE_API_KEY=your_google_api_key_here

OLLAMA_MODEL=your_ollama_model_here
OLLAMA_MODEL_PRO=your_ollama_model_pro_here

USE_PROXY=true|false
HTTPS_PROXY=your_proxy_url_here e.g., http://
HTTP_PROXY=your_proxy_url_here e.g., http://

PROVIDER=only for build or vercel deployment, not needed for local development. Set it to 'ollama' or 'google' to specify the provider for the build version. If not set, it will default to 'openrouter'.